# VELEGRAD environment template (Story 1.1).
# Copy to .env and fill in real values. NEVER commit .env.

# Django secret key — generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Debug flag (True locally, False in production)
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL connection URL
DATABASE_URL=postgres://velegrad:velegrad@localhost:5432/velegrad

# Non-default admin path (must NOT be 'admin/')
ADMIN_URL=velegrad-cms/

# Storage backend: local | s3
STORAGE_BACKEND=local

# Email (SMTP) — prod šalje preko Loopia mejl hostinga. Kredencijali SAMO ovde
# (.env, chmod 600) — NIKAD u repo. EMAIL_HOST_USER = ceo mejl nalog.
# Port 587 = STARTTLS (EMAIL_USE_TLS=True); alternativa 465 = SSL (EMAIL_USE_SSL=True).
# Samo prod (dev=console, test=locmem backend); EMAIL_* se čita u config/settings/prod.py.
EMAIL_HOST=mailcluster.loopia.se
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@velegradbg.rs
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Velegrad Estate <noreply@velegradbg.rs>

# Google Analytics
GOOGLE_ANALYTICS_ID=

# Production shared cache (Story 6.4) — Redis za django-ratelimit deljen brojač.
# REDIS_URL je prihvatljiv alias. Samo prod (dev/test koriste LocMemCache).
CACHE_URL=redis://127.0.0.1:6379/1

# Pouzdani proxy IP-jevi (Nginx) za non-spoofable klijentski IP (Story 6.4 AC6b).
# Comma-separated; default 127.0.0.1 (Nginx na istom hostu).
IPWARE_TRUSTED_PROXY_LIST=127.0.0.1
