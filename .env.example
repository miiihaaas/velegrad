# VELEGRAD environment template (Story 1.1).
# Copy to .env and fill in real values. NEVER commit .env.

# Django secret key — generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Debug flag (True locally, False in production)
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL connection URL
DATABASE_URL=postgres://velegrad:velegrad@localhost:5432/velegrad

# Non-default admin path (must NOT be 'admin/')
ADMIN_URL=velegrad-cms/

# Storage backend: local | s3
STORAGE_BACKEND=local

# Mailgun (email). MAILGUN_SENDER_DOMAIN = verifikovan sending domen (npr. mg.velegradbg.rs).
# MAILGUN_API_URL: US (default) = https://api.mailgun.net/v3 ; EU = https://api.eu.mailgun.net/v3
MAILGUN_API_KEY=
MAILGUN_SENDER_DOMAIN=
MAILGUN_API_URL=https://api.mailgun.net/v3
DEFAULT_FROM_EMAIL=Velegrad <noreply@example.com>

# Google Analytics
GOOGLE_ANALYTICS_ID=

# Production shared cache (Story 6.4) — Redis za django-ratelimit deljen brojač.
# REDIS_URL je prihvatljiv alias. Samo prod (dev/test koriste LocMemCache).
CACHE_URL=redis://127.0.0.1:6379/1

# Pouzdani proxy IP-jevi (Nginx) za non-spoofable klijentski IP (Story 6.4 AC6b).
# Comma-separated; default 127.0.0.1 (Nginx na istom hostu).
IPWARE_TRUSTED_PROXY_LIST=127.0.0.1
